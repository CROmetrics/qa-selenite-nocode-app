{
  "manifest_version": 3,
  "name": "Selenite — No-Code QA Runner",
  "version": "1.0.0",
  "description": "Build and run QA test scripts directly in your browser — no code required.",
  "incognito": "split",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab",
    "sidePanel",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open Selenite",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
